# --- Stage 1: Build Stage ---
FROM python:3.11-slim AS builder
WORKDIR /app

# Install compiler tools needed ONLY for building dependencies
RUN apt-get update && apt-get install -y libpq-dev gcc && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
# Install wheels to a temporary local directory
RUN pip install --no-cache-dir --user -r requirements.txt


# --- Stage 2: Final Runtime Stage ---
FROM python:3.11-slim
WORKDIR /app

# Install ONLY the runtime library for Postgres (no heavy compiler toolchains!)
RUN apt-get update && apt-get install -y libpq5 && rm -rf /var/lib/apt/lists/*

# Copy the pre-compiled packages directly from the builder stage
COPY --from=builder /root/.local /root/.local
COPY . .

# Ensure Python can find our copied packages
ENV PATH=/root/.local/bin:$PATH

EXPOSE 8000
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]